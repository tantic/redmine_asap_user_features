<!-- Colonne du milieu : liste -->
<div class="flex-none basis-[350px] shrink-0 shadow-xs border-r border-gray-100 dark:border-gray-700 flex flex-col">

  <!-- Barre de recherche -->
  <div class="px-3 py-3 border-b border-gray-100 dark:border-gray-700 sticky top-0 bg-white dark:bg-gray-800 z-10">
    <input type="text"
           placeholder="Rechercher..."
           data-action="input->inbox#search"
           data-inbox-target="searchInput"
           class="w-full border border-gray-200 dark:border-gray-600 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 dark:bg-gray-700 dark:text-gray-100">
  </div>

  <!-- Conteneur scrollable -->
  <div class="overflow-auto flex-1">
    <!-- Liste (remplacée au refresh) -->
    <div data-inbox-target="list">
      <%= render partial: "list", locals: { issues: issues } %>
    </div>
    <!-- Lien "charger plus" -->
    <div data-inbox-target="loadMore"
         data-source="<%= list_source %>"
         data-offset="50"
         class="px-4 py-3 <%= has_more ? '' : 'hidden' %>">
      <button data-action="click->inbox#loadMore"
              class="w-full text-xs text-blue-600 dark:text-blue-400 hover:underline cursor-pointer">
        Charger 50 de plus
      </button>
    </div>
  </div>

</div>
