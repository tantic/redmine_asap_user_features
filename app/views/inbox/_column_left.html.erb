<!-- Colonne gauche -->
<div class="flex-none basis-auto md:basis-[280px] shrink-0 p-4 shadow-xs border-r border-gray-100 dark:border-gray-500 dark:bg-gray-800 mt-4">
  <ul class="space-y-2">
    <li class="rounded p-2 hover:bg-gray-100 dark:hover:bg-gray-700 <%= 'font-semibold text-blue-600! dark:text-blue-300! bg-gray-100 dark:bg-gray-700' if (current_page?(my_space_inbox_index_path) || (current_page?(my_space_inbox_path())  rescue false) ) %>">
      <%= link_to my_space_inbox_index_path, class: 'flex text-gray-900! dark:text-gray-300!' do %>
        <%= sprite_icon('inbox', plugin: 'redmine_asap_user_features', css_class: 'stroke-gray-900! dark:stroke-gray-300!') %>
        <span class="ml-2"><%= l(:label_menu_asap_inbox) %>
        (<%= @issues_count %>)</span>
      <% end %>
    </li>
    <li class="rounded p-2 hover:bg-gray-100 dark:hover:bg-gray-700 <%= 'font-semibold text-blue-600! dark:text-blue-300! bg-gray-100 dark:bg-gray-700' if current_page?(watched_my_space_inbox_index_path) %>">
      <%= link_to watched_my_space_inbox_index_path, class: 'flex text-gray-900! dark:text-gray-300!' do %>
        <%= sprite_icon('fav', css_class: 'stroke-gray-900! dark:stroke-gray-300!') %>
        <span class="ml-2"><%= l(:label_menu_asap_watched_issues) %>
        (<%= @issues_watched_count %>)</span>
      <% end %>
    </li>
    <li class="rounded p-2 hover:bg-gray-100 dark:hover:bg-gray-700 <%= 'font-semibold text-blue-600! dark:text-blue-300! bg-gray-100 dark:bg-gray-700' if current_page?(overdue_my_space_inbox_index_path) %>">
      <%= link_to overdue_my_space_inbox_index_path, class: 'flex items-center text-gray-900! dark:text-gray-300!' do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
        <span class="ml-2"><%= l(:label_menu_asap_overdue_issues) %>
        (<%= @issues_overdue_count %>)</span>
      <% end %>
    </li>
  </ul>
</div>